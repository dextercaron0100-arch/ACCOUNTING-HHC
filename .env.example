# Database
DATABASE_URL=postgresql://acct:secret@localhost:5432/accounting
POSTGRES_DB=accounting
POSTGRES_USER=acct
POSTGRES_PASSWORD=secret

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=accounting-docs
S3_REGION=us-east-1

# JWT
JWT_ACCESS_SECRET=change-me-in-production-access
JWT_REFRESH_SECRET=change-me-in-production-refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@accounting.local

# Optional: SSO / SAML
SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=

# Optional: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Microsoft Entra (Azure AD)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
